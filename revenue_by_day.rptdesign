                    <property name="name">cancelled_orders</property>
                    <property name="nativeName">cancelled_orders</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT
    DATE(o.created_at) AS report_date,
    COUNT(o.id) AS total_orders,
    SUM(o.total_amount) AS total_revenue,
    SUM(o.shipping_fee) AS total_shipping,
    COUNT(CASE WHEN o.status = 'PAID' THEN 1 END) AS paid_orders,
    COUNT(CASE WHEN o.status = 'CANCELLED' THEN 1 END) AS cancelled_orders
FROM order_db.orders o
WHERE o.created_at BETWEEN ? AND ?
  AND o.status NOT IN ('PENDING')
GROUP BY DATE(o.created_at)
ORDER BY report_date ASC]]></xml-property>
